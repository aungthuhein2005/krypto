<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/8.0.171"
      spacing="12" styleClass="tab-content">
    <Label text="Activity History" styleClass="section-title"/>
    <HBox spacing="8">
        <ComboBox fx:id="historyFilterComboBox" prefWidth="170" styleClass="algo-combo"/>
        <TextField fx:id="historySearchField" promptText="Search by file name or date" HBox.hgrow="ALWAYS" styleClass="password-field"/>
        <Button text="Clear History" onAction="#handleClearHistory" styleClass="secondary-button"/>
        <Button text="Export CSV" onAction="#handleExportHistory" styleClass="secondary-button"/>
    </HBox>
    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" styleClass="history-table">
        <columns>
            <TableColumn fx:id="historyFileNameCol" text="File Name" prefWidth="220"/>
            <TableColumn fx:id="historyOperationCol" text="Operation" prefWidth="110"/>
            <TableColumn fx:id="historyAlgorithmCol" text="Algorithm" prefWidth="130"/>
            <TableColumn fx:id="historyDateCol" text="Date" prefWidth="180"/>
            <TableColumn fx:id="historyStatusCol" text="Status" prefWidth="140"/>
        </columns>
    </TableView>
</VBox>
